# ===========================================
# SmartNum 智能问数系统 - 环境变量配置
# ===========================================

# ============ LLM 配置 (必需) ============
# 支持 OpenAI 兼容格式：阿里百炼、OpenAI、本地 vLLM 等

# API Key (必填)
LLM_API_KEY=your-api-key-here

# API Base URL
# 阿里百炼: https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI: https://api.openai.com/v1
# 本地 vLLM: http://localhost:8000/v1
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称
# 阿里百炼: qwen-plus, qwen-turbo, qwen-max
# OpenAI: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
LLM_MODEL_NAME=qwen-plus

# 模型参数
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60

# ============ 安全配置 ============
# JWT 密钥 (生产环境请修改为随机字符串)
SECRET_KEY=your-secret-key-here

# Token 有效期 (分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============ MySQL 配置 (必需) ============
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=smartnum
DB_USERNAME=root
DB_PASSWORD=your-password

# ============ 服务配置 ============
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 查询配置
MAX_RESULT_ROWS=1000
QUERY_TIMEOUT=30

# ============ Docker 端口配置 ============
# 前端端口 (默认 80)
FRONTEND_PORT=80
# 后端端口 (默认 8000)
BACKEND_PORT=8000

# ============ CORS 配置 ============
# 允许的源 (JSON 数组格式)
CORS_ORIGINS=["*"]

# RAGFLOW 配置
RAGFLOW_API_BASE=http://172.32.25.1:10001
RAGFLOW_API_KEY=ragflow-xxxxx
RAGFLOW_KNOWLEDGE_BASE_ID=your_kb_id_here